# AppsFly Frontend — variables de entorno (Vite)
# Copiar a .env (local) o configurar en Vercel/Netlify (producción).

VITE_APP_ENV=development
VITE_APP_NAME="Appsfly"
VITE_DEFAULT_LANGUAGE="es"

# API backend
VITE_API_URL=http://localhost:3000/api
VITE_FRONTEND_URL=http://localhost:5173

# Mercado Pago Chile — SOLO clave pública (segura en el cliente)
# Credenciales de prueba: Tus integraciones > Credenciales de prueba
# Producción: Credenciales de producción
VITE_MERCADO_PAGO_PUBLIC_KEY=

# Cloudinary (opcional)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
